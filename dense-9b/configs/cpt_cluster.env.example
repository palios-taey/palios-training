# Copy this file outside git, fill in local values, then source it before
# launching dense 9B CPT. Every path/host is intentionally blank or placeholder
# shaped; the launchers fail loud instead of defaulting to an operator machine.

# Control-host orchestration. Use SSH targets accepted by your environment,
# for example user@node-a,user@node-b,user@node-c,user@node-d.
export NODE_HOSTS_CSV="user@node0,user@node1,user@node2,user@node3"
export NODE_LABELS_CSV="node0,node1,node2,node3"
export REMOTE_REPO_DIR="/absolute/path/to/palios-training"
export SSH_OPTS="-o BatchMode=yes -o ConnectTimeout=10"

# Worker fabric addressing. MASTER_ADDR must be reachable by all ranks.
export NUM_NODES=4
export MASTER_ADDR="fabric-ip-or-hostname-for-rank0"
export MASTER_PORT=29500
export NODE0_IP="fabric-ip-rank0"
export NODE1_IP="fabric-ip-rank1"
export NODE2_IP="fabric-ip-rank2"
export NODE3_IP="fabric-ip-rank3"

# Dense 9B CPT inputs and outputs.
export MODEL_PATH="/absolute/path/to/phase1-sft-or-text-derived-model"
export CPT_DATA="/absolute/path/to/cpt_corpus.jsonl"
export OUTPUT_DIR="/absolute/path/to/cpt-output"
export TOTAL_STEPS="set-from-corpus-manifest"

# Canonical GB10 Adafactor recipe. Override only with a documented reason.
export LR=2e-5
export ADAFACTOR_CLIP_THRESHOLD=1.0
export WARMUP_STEPS=100
export LR_MIN_RATIO=0.0

# Throughput/memory knobs.
export MAX_SEQ=4096
export BATCH_SIZE_PER_RANK=1
export GRAD_ACCUM=4
export SAVE_EVERY=200
export SESSION_LIMIT=200
